# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=stockdash
POSTGRES_PASSWORD=stockdash_dev
POSTGRES_DB=stockdash
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://stockdash:stockdash_dev@db:5432/stockdash

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Finnhub ──────────────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_WS_URL=wss://ws.finnhub.io

# ─── Reddit ───────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=stockdash/1.0

# ─── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ─── Cache TTLs (seconds) ─────────────────────────────────────────────────────
CACHE_TTL_QUOTE=30
CACHE_TTL_CANDLES=300
CACHE_TTL_NEWS=180
CACHE_TTL_MARKET_OVERVIEW=60

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
