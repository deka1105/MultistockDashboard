{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(render:*)",
      "Bash(psql:*)",
      "Bash(redis-cli:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(render deploy*)",
            "command": "jq -r '.tool_input.command' | grep -q 'render deploy' && echo '{\"systemMessage\": \"Render deployment triggered — check render.com dashboard for status.\"}' || true",
            "statusMessage": "Checking Render deploy..."
          }
        ]
      }
    ]
  }
}
